name = "y2pilot-worker"
main = "src/index.ts"
compatibility_date = "2025-01-01"
workers_dev = true

# For local dev with `wrangler dev`, IDs can be any placeholder string —
# Miniflare emulates KV in-memory. Replace with real IDs before deploy:
#   wrangler kv namespace create VIDEOS
#   wrangler kv namespace create PLAYLISTS
[[kv_namespaces]]
binding = "VIDEOS"
id = "your_videos_kv_namespace_id"

[[kv_namespaces]]
binding = "PLAYLISTS"
id = "your_playlists_kv_namespace_id"

[dev]
port = 8787

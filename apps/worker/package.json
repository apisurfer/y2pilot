{
  "name": "@y2pilot/worker",
  "version": "1.0.0",
  "description": "Cloudflare worker for y2pilot",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy --env production",
    "db:migrate:local": "wrangler d1 migrations apply y2pilot-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply y2pilot-db --env production --remote",
    "db:seed:local": "wrangler d1 execute y2pilot-db --local --file=./migrations/seed.sql",
    "db:seed:remote": "wrangler d1 execute y2pilot-db --env production --remote --file=./migrations/seed.sql",
    "format": "prettier --write '**/*.{ts,js,css,json,md}'"
  },
  "license": "MIT OR Apache-2.0",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "wrangler": "^4.0.0"
  },
  "dependencies": {
    "itty-router": "^2.6.6",
    "nanoid": "^5.0.9",
    "p-limit": "^3.1.0"
  }
}
